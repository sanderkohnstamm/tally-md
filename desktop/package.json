    "watch": "esbuild src-ui/main.js --bundle --outfile=ui/bundle.js --format=iife --watch"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.20.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/language-data": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.0",
    "codemirror": "^6.0.0"
  }
}
