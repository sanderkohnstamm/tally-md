{
  "name": "tally-md",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint src-ui/",
    "build": "esbuild src-ui/main.js --bundle --outfile=ui/bundle.js --format=iife --minify",
    "dev": "cargo tauri dev",
